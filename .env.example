# OpenStrat web app configuration.
# Copy this file to .env and fill in real values locally or in your deploy target.
# Do not commit real secrets.

# App/runtime
NEXT_PUBLIC_APP_URL=http://localhost:3000
OPENSTRAT_APP_ENV=development

# Privy auth.
# Map the dashboard's privy_app_id and privy_app_secret into these uppercase
# env names. PRIVY_APP_ID is not a secret and is passed to <PrivyProvider>.
# Do not put PRIVY_APP_SECRET in any NEXT_PUBLIC_* variable.
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional. Only set this if you explicitly create a Privy App Client for this
# web app/environment.
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Wallet/network defaults. Keep aligned with the Stratium trading terminal.
NEXT_PUBLIC_NETWORK_TYPE=testnet
NEXT_PUBLIC_HYPER_EVM_RPC_URL=https://rpcs.chain.link/hyperevm/testnet
NEXT_PUBLIC_HYPER_EVM_MAINNET_RPC_URL=https://rpc.hyperliquid.xyz/evm
NEXT_PUBLIC_HYPER_EVM_TESTNET_RPC_URL=https://rpcs.chain.link/hyperevm/testnet

# Supabase.
# Use the publishable key in browser code. Keep the secret key server-only.
# Use sb_publishable_... and sb_secret_... values from Settings > API Keys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Optional alias for server runtimes that prefer a non-NEXT_PUBLIC name. This
# should be the same value as NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=

# Supabase direct Postgres / ORM (optional).
# Not required for the standard Next.js @supabase/supabase-js or @supabase/ssr
# setup, which uses NEXT_PUBLIC_SUPABASE_URL and
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY in browser/client helpers.
# Set DATABASE_URL only if the app uses Prisma, Drizzle, migrations, or direct
# Postgres queries instead of the Supabase client/Data API.
DATABASE_URL=

# Deployment/runtime worker boundary.
# Keep the initial web refactor limited to authenticated API routes and
# deterministic OpenStrat tool-surface calls. Do not enable live agent loops yet.
OPENSTRAT_AGENT_RUNTIME_ENABLED=false
OPENSTRAT_WORKER_BASE_URL=
OPENSTRAT_OBJECT_STORE_BUCKET=
