{
  "name": "openstrat",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "build": "pnpm -r --sort run build",
    "dev:web": "pnpm --filter @openstrat/web dev",
    "format:check": "prettier --check . \"!**/.next/**\" --ignore-unknown",
    "ingest:hyperliquid": "pnpm --filter @openstrat/market-data ingest:hyperliquid --",
    "lint": "eslint .",
    "start:web": "pnpm --filter @openstrat/web start",
    "smoke:live:hyperliquid": "pnpm --filter @openstrat/market-data smoke:live:hyperliquid",
    "test": "vitest run",
    "typecheck": "pnpm -r --sort run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "typescript": "5.9.3",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
