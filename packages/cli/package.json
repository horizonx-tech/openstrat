{
  "name": "@openstrat/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openstrat": "./dist/openstrat"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex": "0.141.0",
    "@openai/codex-sdk": "^0.141.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@openstrat/domain": "workspace:*",
    "@openstrat/market-data": "workspace:*",
    "@openstrat/persistence": "workspace:*",
    "@openstrat/risk": "workspace:*",
    "@openstrat/workers": "workspace:*",
    "esbuild": "latest"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
